rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny catch-all to secure all collections by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened security helper
    function isSignedIn() {
      return request.auth != null;
    }

    // Students collection: Secure access to authenticated users only
    match /students/{studentId} {
      allow read, write: if isSignedIn();
    }

    // Teachers collection: Secure access to authenticated users only
    match /teachers/{teacherId} {
      allow read, write: if isSignedIn();
    }

    // Settings collection: Publicly readable, modifiable only by authenticated users
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Users / Profiles collection: Publicly readable to allow email role mapping, modifiable by authenticated users
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
